<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A192F">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="Payment and Rating"
            android:textSize="35sp"
            android:textStyle="bold"
            android:textColor="#E6F1FF"
            android:layout_marginBottom="30dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/etAmount"
            android:hint="Enter Payment Amount"
            android:inputType="numberDecimal"
            android:background="#112240"
            android:textColor="#FFFFFF"
            android:textColorHint="#8892B0"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"/>

        <RatingBar
            android:id="@+id/ratingBar"
            android:numStars="5"
            android:stepSize="1"
            android:progressTint="#FFCA28"
            android:secondaryProgressTint="#FFCA28"
            android:progressBackgroundTint="#8892B0"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etReview"
            android:hint="Write a review (optional)"
            android:background="#112240"
            android:textColor="#FFFFFF"
            android:textColorHint="#8892B0"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"/>

        <!-- Submit Button -->
        <Button
            android:id="@+id/btnSubmit"
            android:text="Submit Payment and Rating"
            android:backgroundTint="#1E88E5"
            android:textColor="#FFFFFF"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </LinearLayout>

</ScrollView>