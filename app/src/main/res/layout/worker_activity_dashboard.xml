<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="#A47496"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:text="Worker Dashboard"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#F6EEEA"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="40dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#EAD7D1">

        <LinearLayout
            android:orientation="vertical"
            android:padding="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <Switch
                android:id="@+id/switchAvailability"
                android:text="Available for Work"
                android:textSize="18sp"
                android:textColor="#1F1A38"
                android:layout_marginBottom="24dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/btnJobFeed"
                android:text="View Job Feed"
                android:backgroundTint="#1F1A38"
                android:textColor="#F6EEEA"
                android:padding="12dp"
                android:layout_marginBottom="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/btnProfile"
                android:text="Manage Profile"
                android:backgroundTint="#1F1A38"
                android:textColor="#F6EEEA"
                android:padding="12dp"
                android:layout_marginBottom="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/btnEarnings"
                android:text="View Earnings"
                android:backgroundTint="#1F1A38"
                android:textColor="#F6EEEA"
                android:padding="12dp"
                android:layout_marginBottom="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/btnViewResume"
                android:text="View Resume"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>
