<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A192F">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="Post a New Job"
            android:textSize="35sp"
            android:textStyle="bold"
            android:textColor="#E6F1FF"
            android:layout_marginBottom="30dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/etTitle"
            android:hint="Job Title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#112240"
            android:textColor="#FFFFFF"
            android:textColorHint="#8892B0"
            android:padding="12dp"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/etDesc"
            android:hint="Description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#112240"
            android:textColor="#FFFFFF"
            android:textColorHint="#8892B0"
            android:padding="12dp"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/etLocation"
            android:hint="Location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#112240"
            android:textColor="#FFFFFF"
            android:textColorHint="#8892B0"
            android:padding="12dp"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/etWage"
            android:hint="Wage (per day)"
            android:inputType="numberDecimal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#112240"
            android:textColor="#FFFFFF"
            android:textColorHint="#8892B0"
            android:padding="12dp"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/etDuration"
            android:hint="Duration (days)"
            android:inputType="number"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#112240"
            android:textColor="#FFFFFF"
            android:textColorHint="#8892B0"
            android:padding="12dp"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/etSkills"
            android:hint="Required Skills"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#112240"
            android:textColor="#FFFFFF"
            android:textColorHint="#8892B0"
            android:padding="12dp"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/etCount"
            android:hint="Number of Workers"
            android:inputType="number"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#112240"
            android:textColor="#FFFFFF"
            android:textColorHint="#8892B0"
            android:padding="12dp"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/etDate"
            android:hint="Start Date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#112240"
            android:textColor="#FFFFFF"
            android:textColorHint="#8892B0"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:focusable="false"
            android:clickable="true"/>

        <Button
            android:id="@+id/btnPost"
            android:text="Post Job"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:backgroundTint="#1E88E5"
            android:textColor="#FFFFFF"/>

    </LinearLayout>
</ScrollView>